    {
      "parameters": {
        "jsCode": "// Filter leads where last_contact_date is 3+ days ago\nconst today = new Date();\nconst threeDaysAgo = new Date(today.getTime() - (3 * 24 * 60 * 60 * 1000));\n\nconst staleLeads = [];\n\nfor (const item of $input.all()) {\n  const dateField = item.json.Date || item.json.last_contact_date;\n  \n  if (dateField) {\n    const contactDate = new Date(dateField);\n    \n    // If contact was 3+ days ago, add to stale leads\n    if (contactDate <= threeDaysAgo) {\n      staleLeads.push(item);\n    }\n  }\n}\n\nreturn staleLeads;"
      },
      "id": "filter-stale-leads",
      "name": "Code - Filter Stale Leads (3+ Days)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
